# Latinum Board Operator API environment
# Copy to a secure root-readable location, for example:
#   /etc/latinum-board/operator-api.env
# Then point the systemd unit's EnvironmentFile= to that path.

# Base64-encoded 32-byte sealing key for CRM credential storage.
# Example generation command (do not store the command output in chat/history):
#   python3 -c 'import os,base64; print(base64.b64encode(os.urandom(32)).decode())'
LATINUM_CRM_SECRET_KEY=

# Temporary migration-only flag.
# Set to true only while reading old locally sealed rows before resealing them.
LATINUM_CRM_ALLOW_LOCAL_SECRET_FALLBACK=false
